# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Database - use the Supabase Transaction Pooler URL (port 6543, NOT direct connection port 5432)
# Found in: Supabase Dashboard → Settings → Database → Connection string → Transaction pooler
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
POSTGRES_URL=postgresql://postgres.[project-ref]:your-db-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Resend (Transactional Email)
RESEND_API_KEY=re_your-resend-api-key
RESEND_FROM_EMAIL=noreply@rbmservices.com

# Twilio (SMS Notifications)
TWILIO_ACCOUNT_SID=ACyour-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15551234567

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
